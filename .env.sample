# ── AI provider (required — set at least one) ────────────────────────────────
# Google Gemini is preferred. Both vars are set deliberately:
# pydantic-ai's GoogleProvider reads GOOGLE_API_KEY; older versions read GEMINI_API_KEY.
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Fallback providers (only used if GOOGLE_API_KEY/GEMINI_API_KEY are unset):
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ── Slack app credentials (required) ─────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-YOUR_BOT_TOKEN
SLACK_APP_TOKEN=xapp-YOUR_APP_TOKEN
SLACK_SIGNING_SECRET=YOUR_SIGNING_SECRET

# ── Slack user token for MCP (required for Flow B & C) ───────────────────────
# The Slack MCP Server (mcp.slack.com/mcp) requires a user-scoped OAuth token
# with search:read, channels:history, chat:write, and related scopes.
# In Socket Mode without per-user OAuth, set this to the operator's own user token
# (Settings → OAuth & Permissions → User OAuth Token, or from the OAuth flow).
# This token is the fallback when context.user_token is not available.
SLACK_USER_TOKEN=xoxp-YOUR_USER_TOKEN

# ── Threshold data directory (optional) ──────────────────────────────────────
# Where to store the SQLite impact database (threshold.db).
# Default: ./data (relative to the project root).
# In production on the DigitalOcean droplet, bind-mount the host data directory here:
# THRESHOLD_DATA_DIR=/data
THRESHOLD_DATA_DIR=./data

# Application logging (optional; defaults to INFO in production)
# LOG_LEVEL=DEBUG

# ── OAuth (only needed when running app_oauth.py) ────────────────────────────
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# ── Custom Slack API URL (optional) ──────────────────────────────────────────
# SLACK_API_URL=YOUR_SLACK_API_URL
